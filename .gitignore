# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg

# venv / package manager
.venv/
.uv-cache/
uv.lock.bak

# Tests / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Type checkers / Linter
.mypy_cache/
.ruff_cache/

# IDE
.vscode/
.idea/
*.swp

# Claude Code (lokal akkumulierte Session-Allowlist, user-spezifisch)
.claude/

# OS
Thumbs.db
.DS_Store

# Installer-Build-Artefakte. Werden bei jedem Build neu erzeugt
# (Embedded-Python ~100 MB, nssm.exe ~400 KB, fertige .exe ~18 MB).
installer/bundle/
installer/out/
installer/winget/out/

# OPN-Cockpit runtime data (Sicherheits-Schutz)
# Auch wenn devices.json absichtlich Klartext-Struktur hat (R-NFR-5),
# wird Laufzeit-Datenverzeichnis nie ins Repo geschoben.
appdata/
local-runtime/
*.jsonl
audit.log
audit.jsonl
settings.local.json

# Docs: standardmaessig privat (Arbeitsmaterial, Roadmap, Audit,
# Design-Guide, Test-Plaene, Session-Notes, ...). Nur die zwei
# Endnutzer-Dokumente werden im Public Repo ausgeliefert.
docs/*
!docs/INSTALLATION-WINDOWS.md
!docs/QUICKSTART.md
